# KindCaddy backend environment — copy to .env and fill in your own values.
# .env is gitignored and must never be committed.

# Required: OpenAI API key used for all LLM calls.
OPENAI_API_KEY=sk-your-openai-key-here

# Required in production: secret used to sign JWT auth tokens.
# Generate one with: openssl rand -hex 32
KINDCADDY_JWT_SECRET=change-me-to-a-long-random-secret

# Optional: legacy/simple header auth key shared with clients.
# Generate one with: openssl rand -hex 24
KINDCADDY_API_KEY=

# Optional: SQLite database path (defaults to data/kindcaddy.db).
KINDCADDY_DB_PATH=data/kindcaddy.db

# Optional: iOS Sign-In with Apple — must match the app bundle ID exactly.
APPLE_BUNDLE_ID=com.example.app

# Optional: Google Sign-In OAuth client ID (audience for ID token validation).
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Optional: feature flag to enable subscription/paywall gating end-to-end.
KINDCADDY_SUBSCRIPTIONS_ENABLED=0
